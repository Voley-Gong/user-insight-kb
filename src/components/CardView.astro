---
interface Props {
  id: string;
  title: string;
  module: string;
  tags: string[];
  difficulty: string;
  status: string;
  excerpt?: string;
}

const { id, title, module, tags, difficulty, status, excerpt } = Astro.props;

const slug = id.split('/').pop() || id;
const base = import.meta.env.BASE_URL;

const statusColors: Record<string, string> = {
  draft: 'bg-yellow-500/20 text-yellow-400 border-yellow-500/30',
  review: 'bg-blue-500/20 text-blue-400 border-blue-500/30',
  published: 'bg-green-500/20 text-green-400 border-green-500/30',
};

const difficultyColors: Record<string, string> = {
  '基础': 'bg-emerald-500/20 text-emerald-400 border-emerald-500/30',
  '进阶': 'bg-amber-500/20 text-amber-400 border-amber-500/30',
  '高级': 'bg-red-500/20 text-red-400 border-red-500/30',
};
---

<a
  href={`${base}card/${slug}`}
  class="block bg-[#2a2a3e] border border-[#334155] rounded-xl p-5 hover:border-[#6366f1]/50 hover:bg-[#2a2a3e]/80 transition-all duration-200 group"
>
  <div class="flex items-start justify-between gap-2 mb-3">
    <h3 class="text-white font-semibold text-base group-hover:text-[#818cf8] transition-colors leading-tight">
      {title}
    </h3>
    <span class={`text-xs px-2 py-0.5 rounded-full border whitespace-nowrap ${statusColors[status] || statusColors.draft}`}>
      {status}
    </span>
  </div>

  {excerpt && (
    <p class="text-[#94a3b8] text-sm mb-3 line-clamp-2">{excerpt}</p>
  )}

  <div class="flex flex-wrap gap-1.5 mb-3">
    {tags.slice(0, 3).map((tag) => (
      <span class="text-xs px-2 py-0.5 rounded bg-[#363650] text-[#94a3b8]">
        {tag}
      </span>
    ))}
  </div>

  <div class="flex items-center gap-2 text-xs text-[#64748b]">
    <span class={`px-2 py-0.5 rounded border ${difficultyColors[difficulty] || difficultyColors['基础']}`}>
      {difficulty}
    </span>
    <span>·</span>
    <span>{module}</span>
  </div>
</a>