---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

<div class="bg-[#2a2a3e] border border-[#334155] rounded-xl p-5">
  <h3 class="text-white font-semibold mb-3 flex items-center gap-2">
    <span class="text-[#22c55e]">✅</span>
    设计检查清单
  </h3>
  <ul class="space-y-2">
    {items.map((item) => (
      <li class="flex items-start gap-2 text-sm text-[#cbd5e1]">
        <span class="text-[#6366f1] mt-0.5 shrink-0">☐</span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
</div>
