---
import KnowledgeLayout from '../../layouts/KnowledgeLayout.astro';
import CardView from '../../components/CardView.astro';
import { getCollection } from 'astro:content';
import { MODULES } from '../../data/modules';

export async function getStaticPaths() {
  return MODULES.map((m) => ({
    params: { slug: m.slug },
    props: { moduleData: m },
  }));
}

const { moduleData: mod } = Astro.props;
const allCards = await getCollection('knowledge');

const difficultyOrder = { '基础': 0, '进阶': 1, '高级': 2 };

const moduleCards = allCards
  .filter((c) => {
    const cardModule = c.data.module;
    return cardModule === mod.title || c.id.startsWith(mod.slug.replace('-', '/'));
  })
  .sort((a, b) => {
    const diff = (difficultyOrder[a.data.difficulty] ?? 99) - (difficultyOrder[b.data.difficulty] ?? 99);
    if (diff !== 0) return diff;
    return a.data.title.localeCompare(b.data.title, 'zh-Hans-CN');
  });

const difficultyGroups = [
  { level: '基础', icon: '🟢', cards: moduleCards.filter((c) => c.data.difficulty === '基础') },
  { level: '进阶', icon: '🟡', cards: moduleCards.filter((c) => c.data.difficulty === '进阶') },
  { level: '高级', icon: '🔴', cards: moduleCards.filter((c) => c.data.difficulty === '高级') },
].filter((g) => g.cards.length > 0);
---

<KnowledgeLayout title={mod.title}>
  <div class="mb-8">
    <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/`} class="text-sm text-[#818cf8] hover:text-[#6366f1] mb-2 inline-block">← 返回首页</a>
    <div class="flex items-center gap-3 mb-2">
      <span class="text-4xl">{mod.icon}</span>
      <h1 class="text-3xl font-bold text-white">{mod.title}</h1>
    </div>
    <p class="text-[#94a3b8] text-lg">{mod.description}</p>
    <p class="text-sm text-[#64748b] mt-2">共 {moduleCards.length} 张知识卡片</p>
  </div>

  {moduleCards.length > 0 ? (
    difficultyGroups.map((group) => (
      <div class="mb-10">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-lg">{group.icon}</span>
          <h2 class="text-lg font-semibold text-white">{group.level}</h2>
          <span class="text-sm text-[#64748b]">· {group.cards.length} 篇</span>
          <div class="flex-1 h-px bg-[#334155] ml-2"></div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {group.cards.map((card) => (
            <CardView
              id={card.id.replace('.md', '')}
              title={card.data.title}
              module={card.data.module}
              tags={card.data.tags}
              difficulty={card.data.difficulty}
              status={card.data.status}
            />
          ))}
        </div>
      </div>
    ))
  ) : (
    <div class="bg-[#2a2a3e] border border-[#334155] rounded-xl p-8 text-center">
      <p class="text-[#94a3b8] text-lg mb-2">该模块暂无内容</p>
      <p class="text-sm text-[#64748b]">AI Agents 正在持续添加知识卡片...</p>
    </div>
  )}
</KnowledgeLayout>
